+      const out = document.getElementById("out");
+      try {
+        if (typeof XLSX === "undefined" || !XLSX.read) throw new Error("XLSX missing");
+        const res = await fetch("/New_0722/COOIS.xlsx");
+        if (!res.ok) throw new Error("fetch " + res.status);
